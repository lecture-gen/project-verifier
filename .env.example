OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_ANALYSIS_MODEL=gpt-4o-mini
OPENAI_QUESTION_MODEL=gpt-4o-mini
OPENAI_EVAL_MODEL=gpt-4o-mini
# STT/TTS 는 frontend Web Speech API 가 처리하므로 백엔드 transcribe/tts 키는 기본값만 유지.
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_TRANSCRIBE_LANGUAGE=ko

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=project_evaluation_chunks

APP_SQLITE_PATH=data/app.db
APP_ARTIFACT_DIR=data/artifacts

# 학생 입장 URL 등 백엔드가 redirect 에 쓰는 공개 web host (Next.js 프런트).
PUBLIC_WEB_BASE_URL=http://localhost:3000

# 콤마 분리. 정확한 origin 만 허용한다 (와일드카드 금지 — cookie credentials 함께 쓰므로).
CORS_ALLOW_ORIGINS=http://localhost:3000

# 브라우저에서 호출 가능한 백엔드 base URL (next build 시 client bundle 에 인라인됨).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Next.js 서버 컴포넌트 / Route Handler 가 docker network 안에서 직접 호출하는 base.
# docker compose 에서는 http://api:8000, 로컬 개발에서는 NEXT_PUBLIC_API_BASE_URL 과 동일.
INTERNAL_API_BASE_URL=http://localhost:8000
